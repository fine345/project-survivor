; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="dead-week"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.jpg"

[autoload]

MCPRuntime="*uid://c8dfcidpqvwq8"
RecordManager="*res://scripts/game/record_manager.gd"
SettingsManager="*res://scripts/ui/settings_manager.gd"
DifficultyManager="*res://scripts/ui/difficulty_manager.gd"
BGM="*res://scripts/ui/bgm.gd"
SFX="*res://scripts/ui/sfx.gd"

[boot]

boot/splash/image="res://assets/sprites/splash_backgroung.png"
boot/splash/show_image=true
boot/splash/fullsize=true
boot/splash/minimum_display_time=1.5
boot/splash/show_godot_splash=false

[display]

window/size/viewport_width=720
window/size/viewport_height=1440
window/stretch/mode="viewport"
window/handheld/orientation=1.0

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[gui]

theme/default_font_antialiasing=0.0
theme/default_font_hinting=0.0
theme/default_theme_scale=2.0
theme/custom="res://default_theme.tres"
theme/default_font="res://font/Uranus_Pixel_11Px.ttf"

